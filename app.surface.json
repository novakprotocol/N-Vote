  "surfaces": [
    {
      "id": "n-vote.board",
      "label": "Public board",
      "commands": [
        "n-vote.open_site",
        "n-vote.submit_request",
        "n-vote.view_top5",
        "n-vote.view_approved_now"
      ]
    },
    {
      "id": "n-vote.owner-actions",
      "label": "Owner-gated copy/display actions",
      "commands": [
        "n-vote.refresh_public_data",
        "n-vote.copy_private_handoff_stub"
      ]
    }
  ],
  "boundary_notes": [
    "copy_private_handoff_stub is a text handoff only.",
    "No runner execution.",
    "No private repo mutation."
  ]
}
